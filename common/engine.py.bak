"""
common/engine.py —v8_core_engine binder & graceful fallback
=============================================================

This is the single seam between Qwen's Python orchestration layer and
DeepSeek's Rust core (compiled by maturin to ``v8_core_engine.pyd``).

Behaviour
---------
* If the compiled extension ``v8_core_engine`` is importable, we re-export its
  classes verbatim (ShmBridge, FeatureEngine, OkxChannel, OrderFSM, MctsPool,
  OkxWsClient) —zero overhead, the real binary.
* If it is NOT importable (e.g. maturin/protoc not yet installed, or running on
  a host without ``/dev/shm``), we fall back to pure-Python stand-ins that honour
  the *exact* signatures declared in ``v8_core_engine.pyi``.

The fallbacks are deliberately faithful to the contract (return types, byte
formats, JSON shapes) so that the orchestrator, gating, settlement, monitor and
the integration test-suite all run end-to-end on any host —and snap onto the
real binary the moment it is built, with no call-site changes.

Use ``ENGINE_BACKEND`` to know which path is live ("native" | "fallback").
"""

from __future__ import annotations

import json
import os
import struct
import threading
import time
from collections import deque
from typing import Any, Callable, Deque, Optional, Tuple

# ---------------------------------------------------------------------------
# Attempt to bind the real Rust extension.
# ---------------------------------------------------------------------------
ENGINE_BACKEND: str
try:  # pragma: no cover - exercised only when the .pyd is built
    import v8_core_engine as _native  # type: ignore

    ShmBridge = _native.ShmBridge
    FeatureEngine = _native.FeatureEngine
    OkxChannel = _native.OkxChannel
    OrderFSM = _native.OrderFSM
    MctsPool = _native.MctsPool
    OkxWsClient = _native.OkxWsClient
    ENGINE_BACKEND = "native"

except Exception:  # noqa: BLE001 - any import/abi failure �?fallback
    ENGINE_BACKEND = "fallback"

    _F32 = struct.Struct("<f")

    # === Order FSM state codes (mirror schemas/unified_order.proto OrderState) ==
    _STATE_NAMES = {
        0: "UNSPECIFIED",
        1: "NEW",
        2: "POSTED",
        3: "PARTIAL_FILLED",
        4: "FILLED",
        5: "PARTIAL_CANCELED",
        6: "CANCELED",
        7: "REJECTED",
        8: "EXPIRED",
        9: "UNKNOWN",
        10: "PENDING_CANCEL",
    }
    _TERMINAL = {4, 5, 6, 7, 8}
    # allowed transitions (compile-time-safe FSM, mirrored from order_state.rs)
    _ALLOWED = {
        0: {1},
        1: {2, 7},
        2: {3, 4, 6, 7, 8, 10},
        3: {3, 4, 5, 6, 10},
        10: {5, 6, 3, 4},
    }

    class ShmBridge:  # type: ignore[no-redef]
        """Pure-Python ring buffer stand-in for the mmap2/DLPack Rust bridge.

        Honours v8_core_engine.pyi. ``get_window`` returns a numpy ndarray when
        numpy is available (callers do ``torch.from_dlpack`` on native; on the
        fallback they should accept an ndarray). ``get_raw_ptr`` returns a real
        ctypes-backed pointer over a contiguous float32 buffer.
        """

        _CAP = 4096

        def __init__(self, inst_id: str = "BTC-USDT-SWAP") -> None:
            self._inst = inst_id
            self._cols = 0
            self._buf: Deque[Tuple[int, list[float]]] = deque(maxlen=self._CAP)
            self._lock = threading.Lock()
            self._raw_hold: Any = None  # keep ctypes buffer alive for get_raw_ptr

        def push_snapshot(self, ts_ms: int, features: list[float]) -> None:
            with self._lock:
                self._cols = len(features)
                self._buf.append((int(ts_ms), [float(x) for x in features]))

        def _recent(self, secs: int) -> list[list[float]]:
            if not self._buf:
                return []
            now = self._buf[-1][0]
            lo = now - secs * 1000
            return [row for ts, row in self._buf if ts >= lo]

        def get_window(self, secs: int) -> Any:
            rows = self._recent(secs)
            try:
                import numpy as np

                if not rows:
                    return np.zeros((0, self._cols), dtype=np.float32)
                return np.asarray(rows, dtype=np.float32)
            except Exception:  # numpy missing �?list of lists
                return rows

        def get_raw_ptr(self, secs: int) -> Tuple[int, Tuple[int, int]]:
            import ctypes

            rows = self._recent(secs)
            r = len(rows)
            c = self._cols
            flat = [v for row in rows for v in row]
            buf = (ctypes.c_float * (r * c))(*flat)
            self._raw_hold = buf  # prevent GC; mirrors Rust-owned memory lifetime
            addr = ctypes.addressof(buf)
            return addr, (r, c)

        def get_latest(self) -> Optional[bytes]:
            with self._lock:
                if not self._buf:
                    return None
                ts, row = self._buf[-1]
            snap = {
                "inst_id": self._inst,
                "ts_ms": ts,
                "pulse_id": len(self._buf),
                "features": row,
            }
            return json.dumps(snap).encode("utf-8")

        def stats(self) -> Tuple[int, int]:
            return (len(self._buf), self._CAP)

        def inst_id(self) -> str:
            return self._inst

    class FeatureEngine:  # type: ignore[no-redef]
        """50-dim feature engine stand-in.

        Computes a deterministic-but-plausible 50d vector from the rolling close
        series so downstream gating/alpha logic has real numbers to act on.
        """

        DIM = 50

        def __init__(self, inst_id: str = "BTC-USDT-SWAP") -> None:
            self._inst = inst_id
            self._prices: Deque[float] = deque(maxlen=4096)
            self._bars: list[dict] = []
            self._pulse = 0
            self._funding = 0.0
            self._funding_cum = 0.0
            self._cur_bar: Optional[dict] = None

        def on_tick(self, snapshot_bytes: bytes) -> None:
            try:
                snap = json.loads(snapshot_bytes.decode("utf-8"))
            except Exception:
                return
            px = float(snap.get("last_px") or snap.get("mid_price") or 0.0)
            if px <= 0:
                # try orderbook mid
                b = float(snap.get("bid1", 0.0))
                a = float(snap.get("ask1", 0.0))
                if b > 0 and a > 0:
                    px = (a + b) / 2.0
            if px <= 0:
                return
            self._prices.append(px)
            if self._cur_bar is None:
                self._cur_bar = {"o": px, "h": px, "lo": px, "c": px, "n": 1}
            else:
                b = self._cur_bar
                b["h"] = max(b["h"], px)
                b["lo"] = min(b["lo"], px)
                b["c"] = px
                b["n"] += 1

        def on_5m_close(self) -> bytes:
            self._pulse += 1
            bar = self._cur_bar or {"o": 0, "h": 0, "lo": 0, "c": 0, "n": 0}
            bar = {**bar, "ts_ms": int(time.time() * 1000), "pulse_id": self._pulse}
            self._bars.append(bar)
            self._cur_bar = None
            event = {
                "event": "bar_close",
                "inst_id": self._inst,
                "pulse_id": self._pulse,
                "bar": bar,
                "features_dim": self.DIM,
            }
            return json.dumps(event).encode("utf-8")

        def get_features_50d(self) -> bytes:
            import math

            prices = list(self._prices)[-60:]
            feats = [0.0] * self.DIM
            if prices:
                last = prices[-1]
                feats[0] = prices[0]
                feats[1] = max(prices)
                feats[2] = min(prices)
                feats[3] = last
                feats[4] = float(len(prices))
                if len(prices) > 1:
                    rets = [
                        (prices[i] - prices[i - 1]) / prices[i - 1]
                        for i in range(1, len(prices))
                        if prices[i - 1]
                    ]
                    if rets:
                        mean = sum(rets) / len(rets)
                        var = sum((x - mean) ** 2 for x in rets) / len(rets)
                        feats[5] = mean              # momentum proxy
                        feats[6] = math.sqrt(var)    # realized vol proxy
                        feats[7] = rets[-1]          # last return
                feats[8] = self._funding
                feats[9] = self._funding_cum
            return b"".join(_F32.pack(v) for v in feats)

        def set_funding_rate(self, rate: float, cum: float) -> None:
            self._funding = float(rate)
            self._funding_cum = float(cum)

        def close_series(self, n: int) -> list[float]:
            return [b["c"] for b in self._bars[-n:]]

        def stats(self) -> Tuple[int, int, int]:
            return (len(self._prices), len(self._bars), self._pulse)

    class OkxChannel:  # type: ignore[no-redef]
        """OKX REST signer stand-in —builds the same signed-request JSON shape.

        Uses hmac-sha256 just like ring on the Rust side, so the produced
        signature header is structurally identical (base64(hmac(secret, prehash))).
        """

        def __init__(
            self,
            api_key: str,
            secret_key: str,
            passphrase: str,
            is_demo: bool = True,
        ) -> None:
            self._key = api_key
            self._secret = secret_key.encode("utf-8")
            self._pass = passphrase
            self._demo = is_demo
            self._offset = 0
            self._tokens = 20.0
            self._cap = 20.0

        def _ts(self) -> str:
            # OKX expects ISO8601 millis, e.g. 2020-12-08T09:08:57.715Z
            t = time.time() + self._offset / 1000.0
            ms = int((t - int(t)) * 1000)
            return time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime(t)) + f".{ms:03d}Z"

        def sign(self, timestamp: str, method: str, path: str, body: str) -> str:
            import base64
            import hmac
            import hashlib

            prehash = f"{timestamp}{method.upper()}{path}{body}".encode("utf-8")
            mac = hmac.new(self._secret, prehash, hashlib.sha256).digest()
            return base64.b64encode(mac).decode("ascii")

        def _build(self, method: str, path: str, body_obj: Any) -> bytes:
            body = json.dumps(body_obj, separators=(",", ":")) if body_obj is not None else ""
            ts = self._ts()
            sig = self.sign(ts, method, path, body)
            req = {
                "method": method,
                "url": ("https://www.okx.com" if not self._demo else "https://www.okx.com") + path,
                "headers": {
                    "OK-ACCESS-KEY": self._key,
                    "OK-ACCESS-SIGN": sig,
                    "OK-ACCESS-TIMESTAMP": ts,
                    "OK-ACCESS-PASSPHRASE": self._pass,
                    "Content-Type": "application/json",
                    **({"x-simulated-trading": "1"} if self._demo else {}),
                },
                "body": body,
            }
            return json.dumps(req).encode("utf-8")

        def place_order(self, order_bytes: bytes) -> bytes:
            try:
                order = json.loads(order_bytes.decode("utf-8"))
            except Exception:
                order = {}
            body = {
                "instId": order.get("inst_id", "BTC-USDT-SWAP"),
                "tdMode": order.get("td_mode", "cross"),
                "side": order.get("side", "buy"),
                "ordType": order.get("order_type", "limit"),
                "sz": order.get("sz", "0"),
                "px": order.get("px", ""),
                "clOrdId": order.get("cl_ord_id", "")[:32],
                "tag": order.get("tag", "")[:16],
            }
            return self._build("POST", "/api/v5/trade/order", body)

        def cancel_order(self, ord_id: str, inst_id: str = "BTC-USDT-SWAP") -> bytes:
            return self._build(
                "POST", "/api/v5/trade/cancel-order", {"instId": inst_id, "ordId": ord_id}
            )

        def sync_time(self) -> None:
            self._offset = 0  # no network in fallback

        def get_time_offset_ms(self) -> int:
            return self._offset

        def rate_limiter_status(self) -> str:
            return json.dumps({"tokens": self._tokens, "capacity": self._cap})

        def is_demo(self) -> bool:
            return self._demo

    class OrderFSM:  # type: ignore[no-redef]
        def __init__(self, cl_ord_id: str, inst_id: str, trace_id: str = "") -> None:
            if len(cl_ord_id) > 32:
                raise ValueError("cl_ord_id must be <= 32 chars (OKX hard limit)")
            if len(trace_id) > 32:
                raise ValueError("trace_id must be <= 32 chars")
            self._cl = cl_ord_id
            self._inst = inst_id
            self._trace = trace_id
            self._state = 1  # NEW
            self._ord_id: Optional[str] = None
            self._hist: list[tuple[int, int]] = [(1, int(time.time() * 1000))]
            self._fill_sz = 0.0
            self._fill_px = 0.0
            self._fee = 0.0

        def transition(self, to_state: int, reason: str) -> None:
            allowed = _ALLOWED.get(self._state, set())
            if to_state not in allowed and to_state != self._state:
                raise ValueError(
                    f"invalid transition {_STATE_NAMES.get(self._state)} -> "
                    f"{_STATE_NAMES.get(to_state, to_state)}"
                )
            self._state = to_state
            self._hist.append((to_state, int(time.time() * 1000)))

        def set_ord_id(self, ord_id: str) -> None:
            self._ord_id = ord_id

        def update_fill(self, fill_px: float, fill_sz: float, fee: float) -> None:
            self._fill_px = float(fill_px)
            self._fill_sz = float(fill_sz)
            self._fee = float(fee)

        @property
        def state(self) -> int:
            return self._state

        def state_name(self) -> str:
            return _STATE_NAMES.get(self._state, "UNKNOWN")

        def is_terminal(self) -> bool:
            return self._state in _TERMINAL

        @property
        def cl_ord_id(self) -> str:
            return self._cl

        @property
        def ord_id(self) -> Optional[str]:
            return self._ord_id

        @property
        def inst_id(self) -> str:
            return self._inst

        @property
        def trace_id(self) -> str:
            return self._trace

        def history(self) -> list[tuple[int, int]]:
            return list(self._hist)

        def to_json(self) -> str:
            return json.dumps(
                {
                    "cl_ord_id": self._cl,
                    "ord_id": self._ord_id,
                    "inst_id": self._inst,
                    "trace_id": self._trace,
                    "state": self._state,
                    "state_name": self.state_name(),
                    "fill_sz": self._fill_sz,
                    "fill_px": self._fill_px,
                    "fee": self._fee,
                    "history": self._hist,
                }
            )

    class MctsPool:  # type: ignore[no-redef]
        """Single-thread MCTS stand-in. Calls rollout_fn once per simulation
        budget (capped) and aggregates expected value —enough to exercise the
        Qwen executor path; the real parallel UCB1 search lives in mcts_core.rs.
        """

        def __init__(self, workers: int = 8, timeout_ms: int = 100) -> None:
            self._workers = workers
            self._timeout = timeout_ms

        def run_sync(
            self, state_bytes: bytes, rollout_fn: Callable[[bytes], bytes]
        ) -> bytes:
            deadline = time.time() + self._timeout / 1000.0
            sims = 0
            total_ev = 0.0
            best_ev = -1e18
            best_action = "hold"
            best_pos = "0"
            while time.time() < deadline and sims < 64:
                try:
                    out = rollout_fn(state_bytes)
                    parsed = json.loads(out.decode("utf-8")) if out else {}
                    ev = float(parsed.get("predicted_return", 0.0))
                    conf = float(parsed.get("confidence", 0.0))
                    score = ev * conf
                    total_ev += score
                    if score > best_ev:
                        best_ev = score
                        best_action = "buy" if ev > 0 else ("sell" if ev < 0 else "hold")
                        best_pos = f"{conf:.3f}"
                except Exception:
                    pass
                sims += 1
            return json.dumps(
                {
                    "best_action": best_action,
                    "best_position": best_pos,
                    "expected_value": (total_ev / sims) if sims else 0.0,
                    "visit_count": sims,
                    "total_simulations": sims,
                    "is_degraded": sims < 16,
                }
            ).encode("utf-8")

        def config_info(self) -> str:
            return json.dumps({"workers": self._workers, "timeout_ms": self._timeout})

    class OkxWsClient:  # type: ignore[no-redef]
        """WS client stand-in —yields synthetic snapshots so the pipeline can be
        driven in CI / dry-run without a live OKX socket. The real Tokio client
        lives in adapters/okx_ws.rs.
        """

        def __init__(self, inst_id: str = "BTC-USDT-SWAP") -> None:
            self._inst = inst_id
            self._running = False
            self._px = 3000.0
            self._n = 0
            self._lock = threading.Lock()

        def start(self) -> None:
            self._running = True

        def stop(self) -> None:
            self._running = False

        def latest_snapshot(self) -> Optional[str]:
            if not self._running:
                return None
            import random

            with self._lock:
                self._n += 1
                self._px *= 1.0 + random.uniform(-0.0008, 0.0008)
                px = round(self._px, 2)
                spread = round(px * 0.0001, 4)
            return json.dumps(
                {
                    "ts_ms": int(time.time() * 1000),
                    "inst_id": self._inst,
                    "last_px": px,
                    "last_sz": round(random.uniform(0.1, 5.0), 3),
                    "bid1": round(px - spread / 2, 2),
                    "bid1_sz": round(random.uniform(1, 50), 2),
                    "ask1": round(px + spread / 2, 2),
                    "ask1_sz": round(random.uniform(1, 50), 2),
                    "spread": spread,
                    "tick_count": self._n,
                }
            )

        def is_running(self) -> bool:
            return self._running


def backend() -> str:
    """Return the live engine backend: 'native' or 'fallback'."""
    return ENGINE_BACKEND


def is_native() -> bool:
    return ENGINE_BACKEND == "native"


__all__ = [
    "ShmBridge",
    "FeatureEngine",
    "OkxChannel",
    "OrderFSM",
    "MctsPool",
    "OkxWsClient",
    "ENGINE_BACKEND",
    "backend",
    "is_native",
]
