# ============================================================
# QTS V8 · Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- PostgreSQL (Strategy / Account / Risk / Calibration) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=quant
PG_PASSWORD=quant2024
PG_DB=qts_ops

# --- TimescaleDB (Market Data / Features / Labels) ---
TS_HOST=localhost
TS_PORT=5433
TS_USER=quant
TS_PASSWORD=quant2024
TS_DB=qts_market

# --- ClickHouse (Historical Analytics) ---
CH_HOST=localhost
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000
CH_USER=quant
CH_PASSWORD=quant2024
CH_DB=qts_hist

# --- Redis (Hot Cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=quant2024

# --- Kafka (Message Broker) ---
KAFKA_BOOTSTRAP=localhost:9092

# --- MinIO (S3 Object Storage / Parquet Archive) ---
MINIO_ACCESS_KEY=quant
MINIO_SECRET_KEY=quant2024
MINIO_ENDPOINT=localhost:9100

# --- OKX Exchange ---
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- Binance Exchange ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- Yahoo Finance (no key required, but proxy optional) ---
YFINANCE_PROXY=

# --- CFTC COT Report ---
CFTC_USER_AGENT=

# --- Polymarket / Prediction Markets ---
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# --- Polygon RPC (for prediction market on-chain events) ---
POLYGON_RPC=
ALCHEMY_API_KEY=

# --- Notification Channels (optional) ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
